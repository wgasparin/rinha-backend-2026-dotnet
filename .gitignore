# ---------- Challenge dataset artifacts ----------
# Generated by docs-rinha/.../generate-data.sh.
# resources/references.json.gz (~16 MB) IS tracked — it's the official dataset
# the Dockerfile bakes into the image. Uncompressed copies and the C generator's
# build artifacts are not.
references.json
!resources/references.json.gz
data-generator/build/
data-generator/*.o
data-generator/main

# ---------- Secrets / local config ----------
.env
.env.*
!.env.example
src/appsettings.Local.json
src/appsettings.*.Local.json

# ---------- Misc ----------
*.tmp
*.bak
*.orig
